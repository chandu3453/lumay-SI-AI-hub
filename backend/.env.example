# ==================================================
# lumay-si-ai-hub Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ==================================================
# Naming convention: SECTION__FIELD
# Pydantic's env_nested_delimiter="__" maps these to
# nested model attributes (e.g. APPLICATION__NAME -> settings.application.name)

# ---- Application ----
APPLICATION__NAME=lumay-si-ai-hub
APPLICATION__VERSION=1.0.0
APPLICATION__ENVIRONMENT=development
APPLICATION__SECRET_KEY=change-this-to-a-secure-random-secret-key-256-bits
APPLICATION__DEBUG=false

# ---- Database (PostgreSQL) ----
DATABASE__URL=postgresql+asyncpg://lumay_user:change-this-postgres-password@localhost:5432/lumay_si_db
DATABASE__POOL_SIZE=10
DATABASE__MAX_OVERFLOW=20
DATABASE__ECHO=false

# ---- Redis ----
REDIS__URL=redis://:change-this-redis-password@localhost:6379/0
REDIS__MAX_CONNECTIONS=50

# ---- RabbitMQ ----
RABBITMQ__URL=amqp://lumay_mq_user:change-this-rabbitmq-password@localhost:5672/

# ---- OpenSearch ----
OPENSEARCH__URL=http://localhost:9200
OPENSEARCH__USER=admin
OPENSEARCH__PASSWORD=change-this-opensearch-password
OPENSEARCH__USE_SSL=false

# ---- MinIO (Object Storage) ----
MINIO__ENDPOINT=localhost:9000
MINIO__ACCESS_KEY=lumay_minio_access
MINIO__SECRET_KEY=change-this-minio-secret-key
MINIO__SECURE=false
MINIO__DEFAULT_BUCKET=lumay-documents

# ---- JWT Authentication ----
JWT__SECRET_KEY=change-this-to-a-secure-jwt-secret-key
JWT__ALGORITHM=HS256
JWT__ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT__REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- CORS ----
CORS__ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS__ALLOW_CREDENTIALS=true

# ---- Azure OpenAI ----
AZURE_OPENAI__ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI__API_KEY=change-this-azure-openai-key
AZURE_OPENAI__API_VERSION=2024-02-01
AZURE_OPENAI__DEPLOYMENT_GPT4=gpt-4o
AZURE_OPENAI__DEPLOYMENT_EMBEDDING=text-embedding-3-large

# ---- OpenAI (Fallback) ----
OPENAI__API_KEY=change-this-openai-key
OPENAI__MODEL=gpt-4o
OPENAI__EMBEDDING_MODEL=text-embedding-3-large

# ---- Logging ----
LOGGING__LEVEL=INFO
LOGGING__FORMAT=json

# ---- Monitoring & Observability ----
OBSERVABILITY__OTEL_ENABLED=false
OBSERVABILITY__OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OBSERVABILITY__OTEL_SERVICE_NAME=lumay-si-ai-hub-backend
OBSERVABILITY__OTEL_ENVIRONMENT=development

# ---- AI Platform ----
AI__DEFAULT_PROVIDER=azure_openai
AI__DEFAULT_MODEL=gpt-4o
AI__DEFAULT_EMBEDDING_MODEL=text-embedding-3-large
AI__MAX_RETRIES=3
AI__REQUEST_TIMEOUT_SECONDS=60
AI__MAX_TOKENS_DEFAULT=4096
AI__TEMPERATURE_DEFAULT=0.0
AI__FALLBACK_PROVIDER=
AI__ENABLED=true

# ---- AI Pricing ----
AI_PRICING__GPT4O_PER_1K_PROMPT=0.0025
AI_PRICING__GPT4O_PER_1K_COMPLETION=0.01
AI_PRICING__GPT4O_MINI_PER_1K_PROMPT=0.00015
AI_PRICING__GPT4O_MINI_PER_1K_COMPLETION=0.0006
AI_PRICING__EMBEDDING_PER_1K_TOKENS=0.00013

# ---- Feature Flags ----
FEATURES__AI_ENABLED=true
FEATURES__SENTIMENT_ANALYSIS=true
FEATURES__PII_REDACTION=true
FEATURES__AUDIT_LOG=true
